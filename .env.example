# BINANCE API CONFIGURATION

# Get these from: Binance → API Management
# IMPORTANT: Enable "Enable Spot & Margin Trading" only
# DO NOT enable withdrawal permissions!
BINANCE_API_KEY=your_api_key_here
BINANCE_SECRET_KEY=your_secret_key_here


# EMAIL ALERTS (Gmail)

# For Gmail, use App Password: 
# Google Account → Security → App Passwords
EMAIL_ADDRESS=your_email@gmail.com
EMAIL_PASSWORD=your_16_digit_app_password
RECIPIENT_EMAILS=your_email@gmail.com,backup@example.com

# TRADING PARAMETERS

TRADING_PAIR=ETH/USDT
INITIAL_TRADE_AMOUNT=3000.0
REINVEST_RATIO=1.0
RSI_BUY_THRESHOLD=30
PROFIT_TARGET=0.01
TRAILING_PROFIT_PERCENT=0.001
MAX_ACTIVE_TRADES=4
TRADE_COOLDOWN=7200  # 2 hours in seconds

# BOT BEHAVIOR

CHECK_INTERVAL=30  # Check market every N seconds
TIMEOUT_HOURS=72   # Alert if trade open longer
BOT_ID=ETHUSDT_01


# BINANCE EARN SETTINGS
MINIMUM_SUBSCRIPTION_ETH=0.001
MINIMUM_SUBSCRIPTION_USDT=10.0
REDEMPTION_DELAY=2  # Seconds after redemption